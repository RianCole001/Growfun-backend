
# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=growfun-backend.onrender.com,localhost,127.0.0.1

# Database
DATABASE_URL=your-postgres-url-from-render

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# URLs (production)
FRONTEND_URL=https://dashboard-yfb8.onrender.com
BACKEND_URL=https://growfun-backend.onrender.com

# CoinGecko API (optional - free tier works without key)
COINGECKO_API_KEY=

# MTN Mobile Money Configuration
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_COLLECTION_SUBSCRIPTION_KEY=your_collection_subscription_key
MOMO_DISBURSEMENT_SUBSCRIPTION_KEY=your_disbursement_subscription_key
MOMO_API_USER=your_api_user_uuid
MOMO_API_KEY=your_api_key
MOMO_CALLBACK_URL=https://growfun-backend.onrender.com/api/transactions/momo/callback/
MOMO_ENVIRONMENT=sandbox

# Korapay Configuration
KORAPAY_BASE_URL=https://api.korapay.com/merchant/api/v1
KORAPAY_SECRET_KEY=sk_test_your_secret_key_here
KORAPAY_PUBLIC_KEY=pk_test_your_public_key_here
KORAPAY_ENCRYPTION_KEY=your_encryption_key_here
KORAPAY_WEBHOOK_URL=https://growfun-backend.onrender.com/api/transactions/korapay/webhook/

# ExpressPay Ghana Configuration
EXPRESSPAY_MERCHANT_ID=your-merchant-id
EXPRESSPAY_API_KEY=your-api-key
EXPRESSPAY_SANDBOX=True
# Set EXPRESSPAY_SANDBOX=False when going live
